{
  "name": "paperinsight-desktop",
  "version": "3.0.0",
  "private": true,
  "description": "PaperInsight desktop app built with React and Electron",
  "main": "electron/main.js",
  "author": "WorkBuddy AI Assistant",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --config vite.config.js\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron electron/main.js\"",
    "build": "vite build --config vite.config.js",
    "preview": "vite preview --config vite.config.js",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "vite": "^6.2.2",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.paperinsight.desktop",
    "productName": "PaperInsight",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dist/PaperInsightBackend.exe",
        "to": "backend/PaperInsightBackend.exe"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
