<?xml version="1.0"?>
<package>
  <metadata>
    <id>PaperInsight.Windows</id>
    <version>$version$</version>
    <authors>$authors$</authors>
    <owners>$authors$</owners>
    <license type="expression">MIT</license>
    <projectUrl>$projectUrl$</projectUrl>
    <repository type="git" url="$repositoryUrl$" />
    <description>Standalone Windows executable for the PaperInsight research paper analysis toolkit.</description>
    <readme>README.md</readme>
    <tags>paperinsight windows cli research pdf analysis</tags>
  </metadata>
  <files>
    <file src="$packageDir$\README.md" target="" />
    <file src="$packageDir$\PaperInsight.exe" target="tools" />
    <file src="$packageDir$\config\config.example.yaml" target="tools\config" />
  </files>
</package>
